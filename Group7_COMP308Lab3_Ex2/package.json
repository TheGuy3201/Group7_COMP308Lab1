{
  "name": "game-progress-tracker",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "author": "Joshua Desroches",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10"
  },
  "scripts": {
    "dev": "npm run dev:all",
    "dev:shell": "npm run dev --prefix client/shell-app",
    "dev:auth-app": "npm run dev --prefix client/auth-app",
    "dev:progress-app": "npm run dev --prefix client/game-progress-app",
    "dev:uploads": "nodemon -q server.js",
    "dev:auth-service": "nodemon -q server/microservices/auth-microservice.js",
    "dev:user-service": "nodemon -q server/microservices/user-microservice.js",
    "dev:game-service": "nodemon -q server/microservices/game-microservice.js",
    "dev:gateway": "nodemon -q server/gateway.js",
    "dev:all": "concurrently \"npm run dev:uploads\" \"npm run dev:auth-service\" \"npm run dev:user-service\" \"npm run dev:game-service\" \"npm run dev:gateway\" \"npm run dev:auth-app\" \"npm run dev:progress-app\" \"npm run dev:shell\"",
    "install:all": "npm install; npm install --prefix client/shell-app; npm install --prefix client/auth-app; npm install --prefix client/game-progress-app",
    "build": "vite build",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@originjs/vite-plugin-federation": "^1.3.5",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "global": "^4.4.0",
    "graphql": "^16.12.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "method-override": "^3.0.0",
    "mongoose": "^8.23.0"
  }
}
